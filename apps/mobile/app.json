{
  "expo": {
    "name": "Sprinta",
    "slug": "sprinta",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#6C3EE8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.sprinta.mobile",
      "buildNumber": "1"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#6C3EE8"
      },
      "package": "app.sprinta.mobile",
      "versionCode": 1,
      "permissions": [
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ],
      "expo-audio",
      "expo-font"
    ],
    "scheme": "sprinta",
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "94d2acbc-724f-430d-8d9f-1f40c03a114c"
      },
      "router": {}
    },
    "owner": "erdalk"
  }
}
